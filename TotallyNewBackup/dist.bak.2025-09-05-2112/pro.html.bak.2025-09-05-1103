<!-- FLW-UX-01 ▸ Flow strip honest mode (BTC/ETH/USDT chips) -->
<style>
  .flow-chip .muted { opacity:.65 }
  .flow-chip .quiet { opacity:.8; font-style:italic }
  .flow-chip .up    { color:#22c55e }   /* green */
  .flow-chip .down  { color:#ef4444 }   /* red */
  .flow-chip .flat  { color:#9ca3af }   /* gray */
</style>
<script>
(function(){
  // Map visible label -> API endpoint + a finder that locates the existing chip.
  const SOURCES = {
    'BTC:':      { url: '/api/flow/btc',      label: 'BTC:' },
    'ETH:':      { url: '/api/flow/eth',      label: 'ETH:' },
    'USDT(ETH):':{ url: '/api/flow/usdt-eth', label: 'USDT(ETH):' }
  };

  // Find chip by its starting label text (keeps your current DOM/skin).
  function findChipStart(label){
    const nodes = Array.from(document.querySelectorAll('body *'));
    return nodes.find(n => {
      const t = (n.textContent||'').trim();
      return t.startsWith(label);
    });
  }

  // Normalize whatever the API returns into {to, from, netUsd, pace, mints, burns}
  function normalize(x){
    if (!x || typeof x !== 'object') return null;
    const flat = Object.assign({}, x, x.data||{}, x.result||{});
    // Try different shapes defensively
    const to = +(flat.to ?? flat.in ?? flat.in_count ?? 0);
    const from = +(flat.from ?? flat.out ?? flat.out_count ?? 0);
    const netUsd = +(flat.net_usd ?? flat.netUSD ?? flat.net ?? 0);
    const pace = (flat.pace || flat.activity || '').toString().toLowerCase(); // 'quiet'|'active'|'brisk' etc
    const mints = +(flat.mints ?? flat.mint ?? 0);
    const burns = +(flat.burns ?? flat.burn ?? 0);
    return { to, from, netUsd, pace, mints, burns };
  }

  // Format dollars short
  function fmtUsd(n){
    const s = Math.abs(n) >= 1e9 ? (n/1e9).toFixed(2)+'B'
            : Math.abs(n) >= 1e6 ? (n/1e6).toFixed(2)+'M'
            : Math.abs(n) >= 1e3 ? (n/1e3).toFixed(1)+'k'
            : n.toFixed(0);
    return (n>0?'+':'') + '$' + s;
  }

  // Render rules:
  // - If zero activity → "quiet (no flows last hour)"
  // - If endpoint missing → "no feed"
  // - Else show: "to X / from Y • net ±$N • pace word"
  function renderInto(chipRoot, label, data){
    if (!chipRoot) return;
    chipRoot.classList.add('flow-chip');

    // Identify the container node that actually holds the label & values.
    const container = chipRoot; // good enough in your layout
    const span = document.createElement('span');

    if (data === null) {
      span.innerHTML = `<strong>${label}</strong> <span class="muted">no feed</span>`;
    } else {
      const {to, from, netUsd, pace, mints, burns} = data;

      // Special case: USDT(ETH) – show mints/burns first if present
      if (label.startsWith('USDT')) {
        const quiet = (mints===0 && burns===0 && Math.abs(netUsd)<1);
        if (quiet) {
          span.innerHTML = `<strong>${label}</strong> <span class="quiet">no mints/burns</span>`;
        } else {
          const netCls = netUsd>0 ? 'up' : netUsd<0 ? 'down' : 'flat';
          span.innerHTML =
            `<strong>${label}</strong> mints ${mints} / burns ${burns} • net <span class="${netCls}">${fmtUsd(netUsd)}</span>`;
        }
      } else {
        // BTC/ETH
        const quiet = (to===0 && from===0 && Math.abs(netUsd)<1);
        if (quiet) {
          // If API hints "quiet" / headlines calm, surface that instead of hard zeros
          const paceTag = pace ? ` • ${pace}` : '';
          span.innerHTML = `<strong>${label}</strong> <span class="quiet">quiet (no flows last hour)</span>${paceTag}`;
        } else {
          const netCls = netUsd>0 ? 'up' : netUsd<0 ? 'down' : 'flat';
          const paceTag = pace ? ` • ${pace}` : '';
          span.innerHTML =
            `<strong>${label}</strong> to ${to} / from ${from} • net <span class="${netCls}">${fmtUsd(netUsd)}</span>${paceTag}`;
        }
      }
    }

    // Replace the chip’s text with our friendly version (once per update)
    container.textContent = ''; // clear
    container.appendChild(span);
  }

  async function safeFetch(url){
    try{
      // Respect any global CG mute wrapper already present; we only call your own APIs here
      const res = await fetch(url, { cache:'no-store' });
      if (!res.ok) return null;
      return await res.json();
    } catch { return null; }
  }

  async function refreshOnce(){
    for (const key of Object.keys(SOURCES)){
      const meta = SOURCES[key];
      const root = findChipStart(meta.label);
      if (!root) continue;
      const raw = await safeFetch(meta.url);
      const norm = normalize(raw);
      renderInto(root, meta.label, norm);
    }
  }

  // Initial and periodic refresh
  refreshOnce();
  setInterval(refreshOnce, 60000);
})();
</script>
<!-- END ▸ FLW-UX-01 -->
