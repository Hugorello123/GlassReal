<script>
(function(){
  // --- Placement: tuck next to the "Updated:" chip if found; else pin top-left.
  function placeHB(){
    const pill = document.getElementById('hb-pill');
    if (pill.__placed) return;
    const nodes = Array.from(document.querySelectorAll('body *'));
    const upd = nodes.find(n => n.childNodes && n.childNodes.length === 1 &&
                                typeof n.textContent === 'string' &&
                                n.textContent.trim().startsWith('Updated:'));
    if (upd && upd.parentElement) {
      upd.parentElement.insertBefore(pill, upd.nextSibling);
      pill.style.marginLeft = '10px';
      pill.__placed = true;
    } else {
      // safe fallback
      pill.style.position = 'fixed';
      pill.style.top = '10px';
      pill.style.left = '10px';
      pill.style.zIndex = 9999;
      pill.__placed = true;
    }
  }
  placeHB();

  // --- Heartbeat state + UI updater
  let lastTouch = Date.now() - 120000; // start as stale
  const dot  = document.getElementById('hb-dot');
  const text = document.getElementById('hb-text');

  function renderHB(){
    const age = Math.floor((Date.now() - lastTouch)/1000);
    if (age <= 60) {
      dot.className = 'hb-dot hb-ok';
      text.textContent = `Live • ${age}s`;
    } else if (age <= 90) {
      dot.className = 'hb-dot hb-warn';
      text.textContent = `Quiet • ${age}s`;
    } else {
      dot.className = 'hb-dot hb-dead';
      text.textContent = 'No response';
    }
  }
  setInterval(renderHB, 1000);

  // --- A way for the page to "touch" the heartbeat on successful refresh.
  // 1) Hook fetch() so any successful network call counts as alive.
  if (!window.__hb_fetch_wrapped) {
    window.__hb_fetch_wrapped = true;
    const origFetch = window.fetch.bind(window);
    window.fetch = async function(url, opts){
      try {
        const res = await origFetch(url, opts);
        if (res && res.ok) {
          lastTouch = Date.now();
        }
        // CoinGecko 429 backoff
        const u = (typeof url === 'string') ? url : (url && url.url) || '';
        if (res && res.status === 429 && u.includes('/api/cg/')) {
          // backoff ~2 minutes
          const until = Date.now() + 120000;
          window.__cg_mute_until = until;
          console.warn('CG muted for 120s due to 429 (rate limit).');
        }
        return res;
      } catch (e) {
        return Promise.reject(e);
      }
    };
  }

  // 2) Respect CG mute before kicking off any CG call (if your page calls it directly)
  //    Provide a tiny helper that your existing code can use safely.
  window.cgFetch = async function(url, opts){
    if (window.__cg_mute_until && Date.now() < window.__cg_mute_until) {
      // pretend we’re skipping this request to avoid 429 spam
      throw new Error('cg-muted');
    }
    return fetch(url, opts);
  };

  // 3) One more safety: MutationObserver bumps heartbeat when “Updated:” text changes.
  try {
    const mo = new MutationObserver(() => {
      const n = Array.from(document.querySelectorAll('body *')).find(x =>
        (x.childNodes && x.childNodes.length===1) &&
        typeof x.textContent === 'string' &&
        x.textContent.trim().startsWith('Updated:')
      );
      if (n) lastTouch = Date.now();
    });
    mo.observe(document.body, {subtree:true, childList:true, characterData:true});
