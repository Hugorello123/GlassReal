<!-- HU-FIX-TOOLTIP-02 ▸ Stop native title tooltips in HUD (Now/Action + checks) -->
<script>
(function(){
  // Targets: everything we injected for the human HUD
  const HUD_ROOTS = [
    '#hu-now-action',     // Now/Action pill row
    '#hu-why-line',       // "Why now" line
    '.hu-check',          // Bias ✓ / Money flows ✓ / News pace ✕ badges
    '.hu-signal-line',    // Signal text line (if present)
    '#hu-action-guide'    // Action guide bubble
  ];

  function withinHUD(el){
    try {
      return HUD_ROOTS.some(sel => el.closest(sel));
    } catch(e){ return false; }
  }

  function migrateTitle(el){
    if (!el || !el.hasAttribute('title')) return;
    // Keep the text for accessibility but avoid the browser bubble
    const t = el.getAttribute('title');
    if (t && !el.hasAttribute('aria-label')) el.setAttribute('aria-label', t);
    if (t && !el.hasAttribute('data-hint')) el.setAttribute('data-hint', t);
    el.removeAttribute('title');
  }

  function sweep(container){
    // Remove titles on the container AND on all descendants
    migrateTitle(container);
    container.querySelectorAll('[title]').forEach(migrateTitle);
  }

  // Initial sweep over our HUD areas
  HUD_ROOTS.forEach(sel => {
    document.querySelectorAll(sel).forEach(sweep);
  });

  // Also sweep any children inside those areas
  HUD_ROOTS.forEach(sel => {
    document.querySelectorAll(sel).forEach(node => sweep(node));
  });

  // Keep it clean if something later re-adds a title
  const obs = new MutationObserver(list => {
    for (const m of list) {
      if (m.type === 'attributes' && m.attributeName === 'title') {
        const el = m.target;
        if (withinHUD(el)) migrateTitle(el);
      } else if (m.type === 'childList') {
        m.addedNodes.forEach(n => {
          if (n.nodeType === 1) {
            if (withinHUD(n)) sweep(n);
            n.querySelectorAll?.('[title]').forEach(el => { if (withinHUD(el)) migrateTitle(el); });
          }
        });
      }
    }
  });
  obs.observe(document.body, {subtree:true, childList:true, attributes:true, attributeFilter:['title']});
})();
</script>
<!-- END ▸ HU-FIX-TOOLTIP-02 -->
