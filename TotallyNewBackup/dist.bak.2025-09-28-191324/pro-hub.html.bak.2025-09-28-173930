<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>GlassTrade • Pro Hub</title>
<meta name="description" content="Jump to Signals, Pro Lite, Watchdog, Indices, Legacy Pro, and Guru." />
<style>
:root{--bg:#0b0e13;--bg2:#0f1420;--panel:#121829;--text:#e8eef9;--muted:#a8b3c7;--line:#1e2740;--accent:#6fd3ff;--ok:#3ddc97;--warn:#f5c451}
@media (prefers-color-scheme: light){
  :root{--bg:#f7fbff;--bg2:#eef5ff;--panel:#ffffff;--text:#0b1220;--muted:#5b6b84;--line:#e5ecf6;--accent:#146ce6;--ok:#159c6e;--warn:#b98000}
}
*{box-sizing:border-box} html,body{height:100%}
body{
  margin:0; color:var(--text);
  background:
    radial-gradient(1200px 800px at 100% -10%, rgba(111,211,255,.08), transparent 60%),
    radial-gradient(1200px 800px at -20% 110%, rgba(20,108,230,.08), transparent 60%),
    linear-gradient(0deg, var(--bg2), var(--bg));
  font:16px/1.45 system-ui,-apple-system,Segoe UI,Roboto,Arial;
}
.wrap{max-width:1100px;margin:0 auto;padding:24px}
header{display:flex;align-items:center;justify-content:space-between;gap:16px;margin:6px 0 22px}
.title{font-weight:800;letter-spacing:.2px;margin:0;font-size:clamp(20px,2.4vw,28px);
  background:linear-gradient(90deg,#22d3ee,#3b82f6);-webkit-background-clip:text;background-clip:text;color:transparent}
.subtitle{margin:6px 0 0;color:var(--muted);font-size:14px;max-width:720px}
.header-actions{display:flex;gap:10px;align-items:center}
.back{color:var(--muted);text-decoration:none;border:1px solid var(--line);padding:8px 12px;border-radius:10px}
.back:hover{color:var(--text);border-color:var(--accent)}
.alpha{font-size:12px;color:var(--muted);text-decoration:none;opacity:.85}
.alpha:hover{color:var(--text);opacity:1}
.grid{display:grid;gap:18px;grid-template-columns:repeat(auto-fit,minmax(230px,1fr))}
.card{
  display:flex;flex-direction:column;justify-content:space-between;
  background:linear-gradient(180deg, rgba(255,255,255,.02), rgba(0,0,0,.02)), var(--panel);
  border:1px solid var(--line);border-radius:16px;padding:18px;text-decoration:none;color:inherit;
  transition:transform .06s ease, box-shadow .06s ease, border-color .12s ease;box-shadow:0 6px 20px rgba(0,0,0,.12)
}
.card:hover{transform:translateY(-2px);border-color:rgba(111,211,255,.5);box-shadow:0 10px 28px rgba(0,0,0,.18)}
.row{display:flex;align-items:center;gap:12px}
.icon{width:42px;height:42px;border-radius:11px;display:grid;place-items:center;
  background:linear-gradient(145deg, rgba(111,211,255,.18), rgba(20,108,230,.12));border:1px solid var(--line)}
.card h3{margin:2px 0 2px;font-size:18px}
.desc{color:var(--muted);font-size:14px;margin:6px 0 14px}
.foot{display:flex;align-items:center;gap:10px;margin-top:auto}
.chip{font-size:12px;padding:4px 8px;border-radius:999px;border:1px solid var(--line);color:var(--muted)}
.chip.ok{color:var(--ok)} .chip.warn{color:var(--warn)} .chev{margin-left:auto;opacity:.8}
</style>
</head>
<body>
  <div class="wrap">
