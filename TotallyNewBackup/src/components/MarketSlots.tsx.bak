import React from "react";

const Card: React.FC<{ title: string; children: React.ReactNode }> = ({ title, children }) => (
  <div className="rounded-xl border border-white/10 bg-white/5 backdrop-blur p-4 h-32 md:h-40">
    <div className="text-sm font-medium text-white/80 mb-2">{title}</div>
    <div className="flex flex-wrap gap-x-4 gap-y-1 text-sm">
      {children}
    </div>
  </div>
);

const A: React.FC<React.ComponentProps<"a">> = (props) => (
  <a {...props} className="text-white/70 hover:text-white underline underline-offset-2" target="_blank" rel="noopener noreferrer" />
);

export default function MarketSlots() {
  return (
    <div className="mt-4 grid grid-cols-1 md:grid-cols-2 gap-4">
      <Card title="Equities">
        <A href="https://finance.yahoo.com/quote/%5EGSPC">S&P 500</A>
        <A href="https://finance.yahoo.com/quote/%5ENDX">Nasdaq-100</A>
        <A href="https://finance.yahoo.com/quote/%5EDJI">Dow</A>
        <A href="https://finance.yahoo.com/quote/%5ERUT">Russell 2000</A>
      </Card>

      <Card title="Commodities">
        <A href="https://finance.yahoo.com/quote/GC=F">Gold (Fut)</A>
        <A href="https://finance.yahoo.com/quote/CL=F">WTI Oil (Fut)</A>
        <A href="https://finance.yahoo.com/quote/BZ=F">Brent (Fut)</A>
        <A href="https://finance.yahoo.com/quote/HG=F">Copper (Fut)</A>
      </Card>
    </div>
  );
}
