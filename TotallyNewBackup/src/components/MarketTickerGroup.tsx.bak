// src/components/MarketTickerGroup.tsx
import React, { useEffect, useMemo, useState } from "react";

/* ===== helpers ===== */
const usd = (n: unknown) => {
  const v = Number(n);
  return Number.isFinite(v)
    ? v.toLocaleString(undefined, { style: "currency", currency: "USD", maximumFractionDigits: 0 })
    : "—";
};
const pct = (x: unknown) => {
  const v = Number(x);
  if (!Number.isFinite(v)) return "—";
  const sign = v >= 0 ? "▲" : "▼";
  return `${sign} ${Math.abs(v).toFixed(1)}%`;
};

/* ===== UI row (unchanged API) ===== */
function TickerRow({
  label,
  emoji,
  items,
  speedSec = 36,
}: {
  label: string;
  emoji: string;
  items: string[];
  speedSec?: number;
}) {
  const feed = useMemo(() => (items?.length ? items : ["…loading…"]), [items]);
  const loop = useMemo(() => [...feed, "•", ...feed], [feed]);

  return (
    <div className="my-1 flex items-center gap-3">
      <div className="w-28 text-sm text-gray-400">
        {emoji} {label}
      </div>
      <div className="relative overflow-hidden whitespace-nowrap flex-1">
        <div
          className="inline-block animate-[marquee_linear_infinite]"
          style={{ ["--tw-anim-dur" as any]: `${speedSec}s` }}
        >
          {loop.map((t, i) => (
            <span key={i} className="mx-3 text-sm text-gray-200">
              {t}
            </span>
          ))}
        </div>
      </div>
      <style>{`
        @keyframes marquee { 0%{ transform: translateX(0) } 100%{ transform: translateX(-50%) } }
        .animate-\\[marquee_linear_infinite\\]{ animation: marquee var(--tw-anim-dur,36s) linear infinite; }
      `}</style>
    </div>
  );
}

/* ===== data loaders ===== */
// --- CRYPTO loader: use your proxy to CoinGecko; fallback to Binance ---
async function loadCrypto(): Promise<string[]> {
  const usd = (n: unknown) => {
    const v = Number(n);
    return Number.isFinite(v)
      ? v.toLocaleString(undefined, { style: "currency", currency: "USD", maximumFractionDigits: 0 })
      : "—";
  };
  const pct = (x: unknown) => {
    const v = Number(x);
    if (!Number.isFinite(v)) return "—";
    return `${v >= 0 ? "▲" : "▼"} ${Math.abs(v).toFixed(1)}%`;
  };

  // 1) Try CoinGecko THROUGH YOUR PROXY (bypasses CORS)
  try {
    const r = await fetch(
      "/api/cg/api/v3/simple/price?ids=bitcoin,ethereum,solana,binancecoin&vs_currencies=usd&include_24hr_change=true",
      { headers: { Accept: "application/json" }, cache: "no-store" }
    );
    if (!r.ok) throw new Error(`cg ${r.status}`);
    const j = await r.json();
    const out = [
      `BTC — ${usd(j?.bitcoin?.usd)} (${pct(j?.bitcoin?.usd_24h_change)})`,
      `ETH — ${usd(j?.ethereum?.usd)} (${pct(j?.ethereum?.usd_24h_change)})`,
      `SOL — ${usd(j?.solana?.usd)} (${pct(j?.solana?.usd_24h_change)})`,
      `BNB — ${usd(j?.binancecoin?.usd)} (${pct(j?.binancecoin?.usd_24h_change)})`,
    ];
    // if anything missing, fall through to fallback
    if (out.some(s => s.includes("—"))) throw new Error("cg incomplete");
    return out;
  } catch {
    // 2) Fallback: Binance public (CORS OK, no key)
    try {
      const r2 = await fetch(
        "https://api.binance.com/api/v3/ticker/24hr?symbols=%5B%22BTCUSDT%22,%22ETHUSDT%22,%22SOLUSDT%22,%22BNBUSDT%22%5D",
        { headers: { Accept: "application/json" }, cache: "no-store" }
      );
      if (!r2.ok) throw new Error(`binance ${r2.status}`);
      const arr = await r2.json(); // array of tickers
      const by: Record<string, any> = Object.fromEntries(arr.map((o: any) => [o.symbol, o]));
      return [
        `BTC — ${usd(by.BTCUSDT?.lastPrice)} (${pct(by.BTCUSDT?.priceChangePercent)})`,
        `ETH — ${usd(by.ETHUSDT?.lastPrice)} (${pct(by.ETHUSDT?.priceChangePercent)})`,
        `SOL — ${usd(by.SOLUSDT?.lastPrice)} (${pct(by.SOLUSDT?.priceChangePercent)})`,
        `BNB — ${usd(by.BNBUSDT?.lastPrice)} (${pct(by.BNBUSDT?.priceChangePercent)})`,
      ];
    } catch {
      // Nothing? show placeholders so UI doesn't crash.
      return [];
    }
  }
}


/* ===== main ===== */
export default function MarketTickerGroup() {
  const [crypto, setCrypto] = useState<string[]>([]);
  // other rows: placeholders only (no network calls)
  const equity: string[] = [];
  const commodities: string[] = [];
  const forex: string[] = [];

  useEffect(() => {
    let alive = true;
    (async () => {
      const c = await loadCrypto();
      if (!alive) return;
      setCrypto(c.length ? c : ["BTC —", "ETH —", "SOL —", "BNB —"]);
    })();
    return () => {
      alive = false;
    };
  }, []);

  return (
    <>
      <TickerRow label="Crypto" emoji="🟣" items={crypto} />
      <TickerRow label="Forex" emoji="🟢" items={forex.length ? forex : ["EURUSD —", "USDZAR —", "USDJPY —", "GBPUSD —"]} />
    </>
  );
}
