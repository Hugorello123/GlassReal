// --- Flow endpoints (file-backed; returns zeros if missing/stale) ---
const FLOW_PATH = "/var/lib/glasstrade/flow.json";
const FLOW_TTL  = 60 * 60 * 1000; // 60m while testing

function readFlowSafe(){
  try{
    if (!fs.existsSync(FLOW_PATH)) return null;
    const { mtimeMs } = fs.statSync(FLOW_PATH);
    if (Date.now() - mtimeMs > FLOW_TTL) return null;
    const raw = fs.readFileSync(FLOW_PATH, "utf8");
    return JSON.parse(raw || "{}");
  } catch { return null; }
}

const ZERO_BTC = { to:0, from:0, net:0, state:"quiet" };
const ZERO_ETH = { to:0, from:0, net:0, state:"quiet" };
const ZERO_USDTE = { mints:0, burns:0 };

app.get("/api/flow/btc", (req,res) => {
  const f = readFlowSafe();
  res.status(200).json((f && f.btc) || ZERO_BTC);
});

app.get("/api/flow/eth", (req,res) => {
  const f = readFlowSafe();
  res.status(200).json((f && f.eth) || ZERO_ETH);
});

app.get("/api/flow/usdt_eth", (req,res) => {
