// --- Signals endpoint (reads /var/lib/glasstrade/signals.json) ---
{
  const SIG_PATH = "/var/lib/glasstrade/signals.json";
  app.get("/api/signals/recent", (req,res) => {
    try {
      if (!fs.existsSync(SIG_PATH)) return res.status(200).json([]);
      const raw = fs.readFileSync(SIG_PATH, "utf8");
      let arr = []; try { arr = JSON.parse(raw || "[]"); } catch {}
      if (!Array.isArray(arr)) arr = [];
      const limit = Math.max(1, Math.min(50, parseInt(req.query.limit) || 5));
      arr.sort((a,b)=> new Date(b.t_open).getTime() - new Date(a.t_open).getTime());
      res.setHeader("Cache-Control","no-store");
      return res.status(200).json(arr.slice(0, limit));
    } catch { return res.status(200).json([]); }
  });
}

// ---- CoinGecko pass-through (temporary; bypasses nginx) ----
app.use("/api/cg", async (req, res) => {
  try {
    const upstream = "https://api.coingecko.com" + req.originalUrl.replace(/^\/api\/cg/, "");
    const r = await fetch(upstream, { headers: { "user-agent": "glasstrade-pass" } });
    const body = await r.text(); // stream as-is
    res.setHeader("Cache-Control", "no-store");
    const ct = r.headers.get("content-type") || "application/json; charset=utf-8";
    res.status(r.status).setHeader("Content-Type", ct).send(body);
  } catch (e) {
    console.error("[cg passthrough]", e);
    res.status(502).json({ error: "coingecko_upstream_failed" });
  }
});
