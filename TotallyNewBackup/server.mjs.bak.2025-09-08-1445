const WD_PATH = "/var/lib/glasstrade/watchdog.json";
const STALE_MS = 60 * 60 * 1000; // 15 min

app.get("/api/watchdog/summary", (req, res) => {
  try {
    if (!fs.existsSync(WD_PATH)) return res.status(200).json([]);
    const { mtimeMs } = fs.statSync(WD_PATH);
    if (Date.now() - mtimeMs > STALE_MS) return res.status(200).json([]);
    const raw = fs.readFileSync(WD_PATH, "utf8");
    let data = JSON.parse(raw || "[]");
    if (!Array.isArray(data)) data = [];
    res.setHeader("Cache-Control", "no-store");
    return res.status(200).json(data);
  } catch (e) {
    console.error("[watchdog]", e);
    return res.status(200).json([]);
  }
});
