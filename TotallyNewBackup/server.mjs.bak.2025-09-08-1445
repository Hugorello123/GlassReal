// --- CoinGecko passthrough with 60s cache ---
const CG_BASE = 'https://api.coingecko.com';
let cgCache = { qs: '', ts: 0, data: null };
const CG_TTL_MS = 60_000;

app.get('/api/cg/api/v3/simple/price', async (req, res) => {
  const qs = (req.url.split('?')[1] || '');
  const now = Date.now();

  // serve fresh cache
  if (cgCache.data && cgCache.qs === qs && (now - cgCache.ts) < CG_TTL_MS) {
    return res.status(200).json(cgCache.data);
  }

  try {
    const r = await fetch(`${CG_BASE}/api/v3/simple/price?${qs}`, {
      headers: { 'accept': 'application/json', 'user-agent': 'glasstrade-pro' }
    });
    const data = await r.json();          // parse first
    if (!r.ok) throw new Error(`cg:${r.status}`);
    cgCache = { qs, ts: now, data };      // cache success
    res.setHeader('Cache-Control', 'no-store');
    return res.status(200).json(data);
  } catch (e) {
    // on error/rate-limit, serve last good value (or {})
    return res.status(200).json(cgCache.data || {});
  }
});

