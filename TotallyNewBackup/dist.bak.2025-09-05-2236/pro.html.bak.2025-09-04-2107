<script>
(function(){
  const $ = (id)=>document.getElementById(id);
  const biasEl=$("bias"), scoreEl=$("score"), btcEl=$("btc"), goldEl=$("gold"), heatEl=$("heat"), whyEl=$("why");
  const weekendEl=$("weekend");

  const isWeekendUTC=()=>{const d=new Date().getUTCDay(); return d===0||d===6};
  weekendEl.style.display = isWeekendUTC() ? "inline-block" : "none";

  // helper fetch
  async function j(u){
    try{
      const r=await fetch(u,{cache:"no-store"});
      if(!r.ok) return null;
      return await r.json();
    }catch{ return null; }
  }

  // ---- Bias refresh (no page reload) ----
  async function refreshBias(){
    const prices = await j("/api/cg/api/v3/simple/price?ids=pax-gold,bitcoin&vs_currencies=usd&include_24hr_change=true");
    const goldCh = Number(prices?.["pax-gold"]?.usd_24h_change);
    const btcCh  = Number(prices?.bitcoin?.usd_24h_change);
    const news   = await j("/api/gdelt/gold");
    const headlines = Array.isArray(news?.articles) ? news.articles.length : 0;

    const fmt=(n)=> Number.isFinite(n) ? (n>0? "+" : "") + n.toFixed(2) + "%" : "n/a";
    btcEl.textContent  = fmt(btcCh);
    goldEl.textContent = fmt(goldCh);
    heatEl.textContent = String(headlines);

    let score = 50;  // 50 = neutral
    const why = [];

    if (Number.isFinite(btcCh)) {
      if (btcCh <= -1.5) { score += 8;  why.push("BTC risk-off"); }
      else if (btcCh <= -0.5) { score += 4;  why.push("BTC mild risk-off"); }
      else if (btcCh >=  1.5) { score -= 8;  why.push("BTC risk-on"); }
      else if (btcCh >=  0.5) { score -= 4;  why.push("BTC mild risk-on"); }
      else { why.push("BTC neutral"); }
    }

    if (Number.isFinite(goldCh)) {
      if (goldCh >= 0.7)      { score += 5;  why.push("Gold confirming"); }
      else if (goldCh <= -0.7){ score -= 5;  why.push("Gold drag"); }
      else if (Math.abs(goldCh) >= 0.3) { why.push("Gold slight tone"); }
      else { why.push("Gold flat"); }
    }

    const tape = headlines>=10?"noisy": headlines>=3?"active":"calm";
    if (tape==="noisy") score = Math.round((score-50)*0.8 + 50); // dampen when noisy
    score = Math.max(35, Math.min(65, Math.round(score)));

    const bias =
      score>=65 ? "bullish" :
      score<=35 ? "bearish" :
      score>55  ? "bullish" :
      score<45  ? "bearish" : "neutral";

    scoreEl.textContent = String(score);
    biasEl.textContent  = bias;
    biasEl.classList.remove("bullish","bearish","neutral");
    biasEl.classList.add(bias);
    whyEl.textContent = "Why: " + (why.join(" • ") || "inputs n/a") + " • tape " + tape;

    $("upd").textContent = "Updated: " + new Date().toLocaleTimeString();
  }

  // ---- Analogs (optional) ----
  async function loadAnalogs(){
    const box=$("analogs");
    try{
      const r=await fetch("/analogs/manifest.json",{cache:"no-store"});
      if(!r.ok) return;
      const m=await r.json();
      if(!m?.items?.length) return;
      box.innerHTML="";
      for(const it of m.items){
        const d=document.createElement("div"); d.className="imgbox";
        d.innerHTML = `
          <div class="h2" style="margin-bottom:6px">${(it.title||"Scenario")}</div>
          <img src="${it.img}" alt="${(it.title||"Analog")}" />
          ${it.note? `<div class="muted" style="margin-top:6px">${it.note}</div>`:""}
        `;
        box.appendChild(d);
      }
    }catch{}
  }

  // ---- Exchange / Stablecoin flow pills ----
  async function loadFlow(){
    try{
      const [B,E,U] = await Promise.allSettled([
        j('/api/flow/btc?window_s=1800&min_usd=500000'),   // last 30m, $500k+
        j('/api/flow/eth?window_s=1800&min_usd=500000'),
        j('/api/stable/usdt-eth?window_s=7200')            // last 2h
      ]);
      const money = (n) => (n||0).toLocaleString(undefined,{style:'currency',currency:'USD',maximumFractionDigits:0});
      const pills = [];
      const b=B.value, e=E.value, u=U.value;

      function renderChain(tag, v){
        if (!v) return '';
        const quiet = (v.to_exch.usd + v.from_exch.usd) === 0;
        const net = (v.to_exch.usd||0) - (v.from_exch.usd||0);
        const dir = net>0 ? '→ EXCH' : net<0 ? '← EXCH' : '•';
        const netClass = net>0 ? 'fok' : net<0 ? 'fbad' : 'fmuted';
        const top = v.top?.usd
          ? ` • top <span class="fmono">${money(v.top.usd)}</span>
               <span class="fmuted">${v.top.dir==='to'?'→ EXCH':'← EXCH'}</span>`
          : ` • <span class="fmuted">${quiet?'quiet':'—'}</span>`;
        return `<span class="fpill">
                  ${tag}: to <b>${v.to_exch.count}</b> / from <b>${v.from_exch.count}</b>${top}
                  • net <span class="fmono ${netClass}">${money(Math.abs(net))}</span> <span class="fmuted">${dir}</span>
                </span>`;
      }

      if (b) pills.push(renderChain('BTC', b));
      if (e) pills.push(renderChain('ETH', e));

      if (u){
        const bias = u.mints.usd > u.burns.usd ? 'fok' : (u.mints.usd < u.burns.usd ? 'fbad' : 'fmuted');
        pills.push(
          `<span class="fpill">
            USDT(ETH): <span class="${bias}">mints ${money(u.mints.usd)}</span> / burns ${money(u.burns.usd)}
            ${u.bigprints?.length ? ` • big→exch ${u.bigprints.length}` : ``}
          </span>`
        );
      }

      const box = $("flowPills");
      box.innerHTML = pills.length ? pills.join(' ') : '<span class="fpill fmuted">no flow</span>';
    }catch{
      $("flowPills").innerHTML = '<span class="fpill fbad">flow error</span>';
    }
  }

  // kick everything
  refreshBias();                // initial
  loadAnalogs();                // optional
  loadFlow();                   // initial
  setInterval(refreshBias, 60_000); // bias every 60s
  setInterval(loadFlow, 20_000);    // flow every 20s
})();
</script>
 <!-- Patch S1-B: Hero Signal strip (inserts under bias/implication) -->
<script>
(function(){
  if (document.getElementById('signal-strip')) return; // guard

  function q(s){ return document.querySelector(s); }
  // Prefer to anchor BELOW the implication line if it exists; else below the bias number.
  var anchor = q('#bias-implication') ||
               q('#bias-score') || q('.bias-score') || q('[data-bias]') ||
               q('#biasValue') || q('[data-role="bias-score"]') || q('[data-testid="bias-score"]');

  if (!anchor) { // bias may render async; retry briefly
    let tries = 0;
    const t = setInterval(function(){
      anchor = q('#bias-implication') ||
               q('#bias-score') || q('.bias-score') || q('[data-bias]') ||
               q('#biasValue') || q('[data-role="bias-score"]') || q('[data-testid="bias-score"]');
      if (anchor || ++tries > 40) { clearInterval(t); if (anchor) mount(); }
    }, 250);
  } else {
    mount();
  }

  function insertAfter(ref, node){ ref.parentNode.insertBefore(node, ref.nextSibling); }

  function mount(){
    if (document.getElementById('signal-strip')) return;

    const strip = document.createElement('div');
    strip.id = 'signal-strip';
    strip.setAttribute('role','status');
    Object.assign(strip.style, {
      marginTop:'8px', padding:'6px 10px',
      border:'1px solid rgba(255,255,255,0.08)',
      borderRadius:'10px', background:'rgba(255,255,255,0.03)',
      fontSize:'13px', display:'flex', flexWrap:'wrap',
      alignItems:'center', gap:'8px'
    });

    const strong = document.createElement('strong');
    strong.id = 'signal-label';
    strong.style.letterSpacing = '0.2px';

    const sep = document.createElement('span');
    sep.textContent = '·';
    sep.style.opacity = '0.5';

    const why = document.createElement('span');
    why.id = 'signal-why';
    why.style.opacity = '0.85';

    const link = document.createElement('a');
    link.href = '/predictions.html';
    link.textContent = 'Predictions';
    link.style.textDecoration = 'underline';
    link.style.opacity = '0.9';

    strip.appendChild(strong);
    strip.appendChild(document.createTextNode(' '));
    strip.appendChild(sep);
    strip.appendChild(document.createTextNode(' '));
    strip.appendChild(why);
    strip.appendChild(document.createTextNode('  '));
    strip.appendChild(link);

    insertAfter(anchor, strip);
    refresh();
    setInterval(refresh, 5000);
  }

  function findBiasEl(){
    return q('#bias-score') || q('.bias-score') || q('[data-bias]') ||
           q('#biasValue') || q('[data-role="bias-score"]') || q('[data-testid="bias-score"]');
  }
  function parseBias(el){
    if (!el) return NaN;
    let txt = el.getAttribute('data-bias') || el.textContent || '';
    txt = String(txt).replace(/[^\d.\-:]/g,'');
    if (txt.includes(':')) txt = txt.split(':').pop();
    const n = parseFloat(txt);
    return Number.isFinite(n) ? n : NaN;
  }
  function labelFromBias(b){
    if (Number.isNaN(b)) return {label:'Signal: —', bucket:'awaiting'};
    if (b <= 45) return {label:'Signal: Risk-off', bucket:'risk-off'};
    if (b < 55)  return {label:'Signal: Neutral',  bucket:'neutral'};
    if (b < 75)  return {label:'Signal: Risk-on',  bucket:'risk-on'};
    return {label:'Signal: Strong risk-on', bucket:'strong-risk-on'};
  }
  function readFlowToken(ids){
    for (const sel of ids){
      const el = q(sel);
      if (el && el.textContent){
        const t = el.textContent.toLowerCase();
        if (t.includes('btc') && t.includes('outflow')) return 'BTC outflow';
        if (t.includes('btc') && t.includes('inflow'))  return 'BTC inflow';
        if (t.includes('eth') && t.includes('outflow')) return 'ETH outflow';
        if (t.includes('eth') && t.includes('inflow'))  return 'ETH inflow';
        if (t.includes('mint')) return 'USDT mint';
        if (t.includes('burn')) return 'USDT burn';
        return el.textContent.trim().slice(0,22);
      }
    }
    return null;
  }
  function synthWhy(biasNum){
    const parts = [];
    const b = Math.round(biasNum);
    parts.push(Number.isNaN(b) ? 'Bias: n/a'
      : (b < 46 ? `Bias ${b} → risk-off`
      :  b < 55 ? `Bias ${b} → neutral`
      :  b < 75 ? `Bias ${b} → risk-on`
                : `Bias ${b} → strong risk-on`));
    const btc  = readFlowToken(['#btc-flow','#flow-btc','[data-flow="btc"]','.flow-btc']);
    const eth  = readFlowToken(['#eth-flow','#flow-eth','[data-flow="eth"]','.flow-eth']);
    const usdt = readFlowToken(['#usdt-eth-flow','#flow-usdt-eth','[data-flow="usdt-eth"]','.flow-usdt-eth']);
    if (btc) parts.push(btc); if (eth) parts.push(eth); if (usdt) parts.push(usdt);
    if (!btc && !eth && !usdt) parts.push('Flows: pending');
    return parts.slice(0,3).join(' · ');
  }
  function refresh(){
    const b = parseBias(findBiasEl());
    const {label} = labelFromBias(b);
    const L = document.getElementById('signal-label');
    const W = document.getElementById('signal-why');
    if (L) L.textContent = label;
    if (W) W.textContent = synthWhy(b);
  }
})();
</script>
<!-- Patch H1: Heartbeat status (read-only, tiny) -->
<script>
(function(){
  if (document.getElementById('flow-heartbeat')) return; // guard

  // Create a subtle line at bottom of the page
  var hb = document.createElement('div');
  hb.id = 'flow-heartbeat';
  hb.style.marginTop = '14px';
  hb.style.fontSize = '12px';
  hb.style.opacity = '0.75';
  hb.style.borderTop = '1px solid rgba(255,255,255,0.08)';
  hb.style.paddingTop = '8px';
  hb.textContent = 'Heartbeat: initializing…';
  document.body.appendChild(hb);

  var endpoints = ['/api/flow/btc','/api/flow/eth','/api/flow/usdt-eth'];
  var lastOkTs = null;
  var lastOkEndpoint = '—';
  var sinceSec = 0;

  function setText(txt){
    hb.textContent = txt;
  }

  function withTimeout(fetchPromise, ms){
    var ctrl = new AbortController();
    var t = setTimeout(function(){ ctrl.abort(); }, ms);
    return fetchPromise(ctrl).finally(function(){ clearTimeout(t); });
  }

  async function tryEndpoint(url){
    try {
      await withTimeout(
        (ctrl)=>fetch(url, { method:'GET', cache:'no-store', signal: ctrl.signal }),
        4000
      ).then(function(r){ if (!r.ok) throw new Error('HTTP '+r.status); });
      return true;
    } catch(e) {
      return false;
    }
  }

  async function ping(){
    for (var i=0;i<endpoints.length;i++){
      var ok = await tryEndpoint(endpoints[i]);
      if (ok){
        lastOkTs = Date.now();
        lastOkEndpoint = endpoints[i];
        sinceSec = 0;
        return true;
      }
    }
    return false;
  }

  function render(){
    if (lastOkTs){
      setText('Live • ' + sinceSec + 's • ' + lastOkEndpoint);
    } else {
      setText('No response • ' + sinceSec + 's • /api/flow/*');
    }
  }

  // Kick off: immediate ping, then re-ping every 30s; tick display every 1s
  ping().then(render);
  setInterval(function(){ sinceSec++; render(); }, 1000);
  setInterval(function(){ ping().then(render); }, 30000);
})();
</script>
<!-- Patch QRS-01: quiet recent-signals until API exists (remove to rollback) -->
<script>
(function () {
  try {
    if (window.__quiet_recent_signals) return;
    window.__quiet_recent_signals = true;

    // 1) Hide our recent-signals shell if present
    var wrap = document.getElementById('recent-signal-wrap');
    if (wrap) wrap.style.display = 'none';

    // 2) Silently short-circuit fetches to the placeholder endpoints so DevTools stays clean
    var _origFetch = window.fetch.bind(window);
    window.fetch = function (input, init) {
      try {
        var url = (typeof input === 'string') ? input : (input && input.url) || '';
        if (url && (url.indexOf('/api/signal/recent') !== -1 || url.indexOf('/api/edge/recent') !== -1)) {
          // Return an empty list with HTTP 200 to prevent network 404 spam
          return Promise.resolve(new Response('[]', {
            status: 200,
            headers: { 'Content-Type': 'application/json' }
          }));
        }
      } catch (e) { /* fall through */ }
      return _origFetch(input, init);
    };
  } catch (e) { /* no-op */ }
})();
</script>
