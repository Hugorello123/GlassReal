<!-- HUMAN-UI-01 ▸ Friendly Now/Action, Checks, and Signal (no new APIs) -->
<style>
  .hu-wrap{margin-top:8px;margin-bottom:12px;display:flex;gap:10px;flex-wrap:wrap}
  .hu-chip{display:inline-flex;align-items:center;gap:6px;padding:6px 10px;border-radius:999px;
           background:#1f2a37;border:1px solid rgba(255,255,255,.08);font-size:13px}
  .hu-chip.action{background:#23324a;border-color:rgba(59,130,246,.35)}
  .hu-checks{display:flex;gap:8px;flex-wrap:wrap;margin:10px 0}
  .hu-check{font-size:13px;padding:4px 8px;border-radius:8px;border:1px solid}
  .hu-ok{color:#16a34a;border-color:rgba(22,163,74,.35);background:rgba(22,163,74,.08)}
  .hu-no{color:#f59e0b;border-color:rgba(245,158,11,.35);background:rgba(245,158,11,.08)}
  .hu-note{font-size:12px;opacity:.75;margin-left:4px}
  .hu-signal{margin:10px 0 6px 0;font-size:14px;opacity:.95}
  .hu-muted{opacity:.6}
  @media (max-width:600px){.hu-wrap{gap:6px}.hu-chip{font-size:12px}}
</style>

<script>
(function(){
  if (document.getElementById('hu-now-action')) return; // guard

  // --- helpers --------------------------------------------------------------
  function text(){ return (document.body && document.body.textContent) || ''; }
  function num(re, def=0){
    const m = text().match(re);
    return m ? parseFloat(m[1]) : def;
  }
  function has(re){ return re.test(text()); }
  function el(tag, cls, html){ const e=document.createElement(tag); if(cls) e.className=cls; if(html!=null) e.innerHTML=html; return e; }
  function insertAfter(ref, node){ ref.parentNode.insertBefore(node, ref.nextSibling); }

  // --- derive simple inputs from the page -----------------------------------
  // Bias number, as shown "Bias (56)" anywhere on the page
  const biasVal = num(/Bias[^()]*\(\s*(-?\d+(?:\.\d+)?)\s*\)/i, NaN);
  const haveBias = !isNaN(biasVal);
  const biasLabel = haveBias ? (biasVal>=65?'bullish':(biasVal<=49?'bearish':'neutral')) : 'neutral';

  // Headlines pace, from the "Headlines/hr N" string
  const headlinesHr = num(/Headlines\/hr\s+(\d+)/i, 0);
  const newsHot = headlinesHr >= 3;

  // Flows: look for common words already used on the page
  // (inflow / outflow / mint / burn). If none appear, we call it "waiting".
  const flowsHot = has(/\b(inflow|outflow|mint|burn)\b/i);

  // --- decide Action and Signal sentence ------------------------------------
  let action, signalLine, whyBits = [];
  if (haveBias) whyBits.push(`Bias ${biasVal} (${biasLabel})`);
  whyBits.push(`Headlines ${headlinesHr}/hr`);
  // Action rules: minimal, human
  if (newsHot && flowsHot && haveBias && biasVal>=55){
    action = 'Go (small size)';
    signalLine = 'Signal (1–6h): Mild Bullish — flows + news aligned. Window: 30–90m.';
  } else if (newsHot){
    action = 'Scout';
    signalLine = 'Signal (1–6h): Waiting for flows. News is hot; watch BTC/ETH inflow.';
  } else {
    action = 'Wait';
    signalLine = 'Signal (1–6h): Waiting for confirmation (flows or headlines spike).';
  }

  // Checks row
  const checksWrap = el('div','hu-checks','');
  checksWrap.appendChild(el('span', 'hu-check ' + (haveBias?'hu-ok':'hu-no'),
                           'Bias ' + (haveBias?'✓':'✕') + (haveBias?'' : '<span class="hu-note"> — score not found</span>')));
  checksWrap.appendChild(el('span', 'hu-check ' + (flowsHot?'hu-ok':'hu-no'),
                           'Money flows ' + (flowsHot?'✓':'✕') + (flowsHot?'' : '<span class="hu-note"> — waiting for inflow/outflow</span>')));
  checksWrap.appendChild(el('span', 'hu-check ' + (newsHot?'hu-ok':'hu-no'),
                           'News pace ' + (newsHot?'✓':'✕') + (newsHot?'' : '<span class="hu-note"> — headlines quiet</span>')));

  // Now/Action chips (top)
  const now = el('div','hu-wrap',''); now.id='hu-now-action';
  now.appendChild(el('div','hu-chip','<strong>Now:</strong> ' +
                     (haveBias?`Bias ${biasVal} (${biasLabel})`:'Bias n/a') +
                     ' &nbsp;•&nbsp; Headlines ' + headlinesHr + '/hr'));
  now.appendChild(el('div','hu-chip action','<strong>Action:</strong> ' + action));

  // Signal sentence container
  const sig = el('div','hu-signal', signalLine);

  // --- place it in the page --------------------------------------------------
  // 1) Try to put Now/Action bar where your old chips live (above Session Bias card)
  const firstCard = document.querySelector('h2, h3, .card, .session-bias') || document.body;
  const anchorTop = document.querySelector('.hu-attach-top') || firstCard;
  anchorTop.parentNode.insertBefore(now, anchorTop);

  // 2) Inside Session Bias, under the "Signal" row, show Checks + Signal (1–6h)
  // Find the Signal row; if not present, attach near the first "Session Bias" header.
  let sb = null;
  const h2s = Array.from(document.querySelectorAll('h2,h3')).filter(h => /Session\s+Bias/i.test(h.textContent));
  if (h2s.length) sb = h2s[0].parentElement;
  const signalRow = sb ? sb.querySelector(':scope .hu-signal-slot') || sb : document.querySelector('.hu-signal-slot') || sb || firstCard;

  const holder = el('div','hu-signal-slot','');
  holder.appendChild(checksWrap);
  holder.appendChild(sig);

  // Try to insert right after the visible “Signal:” line; fallback to after the Session Bias header.
  const signalLabel = sb ? sb.querySelector('div,span,li,section') : null;
  if (signalLabel) insertAfter(signalLabel, holder); else insertAfter(signalRow, holder);

  // --- default Alerts ON (first-time) ---------------------------------------
  try {
    const lsKey = 'alr_pref_onboard_v1';
    if (!localStorage.getItem(lsKey)) {
      // flip any known alert chips ON visually
      const labels = [/Headlines\s*spike/i, /Bias\s*flip/i, /Gold\s*heat/i, /Flow/i];
      Array.from(document.querySelectorAll('button, .chip, .pill, .badge')).forEach(b=>{
        const t=(b.textContent||'').trim();
        if (labels.some(r=>r.test(t))) { b.classList.add('on'); b.setAttribute('aria-pressed','true'); }
      });
      localStorage.setItem(lsKey,'1');
    }
  } catch(e){}

  // --- tiny polish: if the tiny top tickers are all zero, show "quiet" -------
  try{
    const strips = Array.from(document.querySelectorAll('div,span')).filter(x =>
      /BTC:\s*to\s*0\s*\/\s*from\s*0/i.test(x.textContent||'') ||
      /ETH:\s*to\s*0\s*\/\s*from\s*0/i.test(x.textContent||''));
    strips.forEach(s=>{
      if (!/quiet/i.test(s.textContent)) s.textContent = s.textContent.replace(/(BTC:|ETH:).*/i, (m)=>
        (m.startsWith('BTC:')?'BTC: ':'ETH: ') + 'quiet');
    });
  }catch(e){}
})();
</script>
