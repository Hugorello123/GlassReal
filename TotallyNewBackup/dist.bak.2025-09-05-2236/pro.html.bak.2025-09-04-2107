      el.style.borderRadius = '999px';
      el.style.border = '1px solid rgba(255,255,255,0.08)';
      el.style.background = 'rgba(255,255,255,0.04)';
      if (tone==='green') el.style.boxShadow = 'inset 0 0 0 999px rgba(0,255,128,0.08)';
      if (tone==='amber') el.style.boxShadow = 'inset 0 0 0 999px rgba(255,200,0,0.08)';
      if (tone==='red') el.style.boxShadow = 'inset 0 0 0 999px rgba(255,80,80,0.08)';
      return el;
    }
    pill(nowSpan);
    pill(actSpan, 'amber');

    bar.appendChild(nowSpan);
    bar.appendChild(actSpan);

    // 2) Insert the bar just under the header area (before the first main card)
    var anchor = document.querySelector('#app') || document.body;
    // Try to put it just above the first big card
    var firstCard = document.querySelector('.card, .panel, [data-card], [role="region"]');
    if (firstCard && firstCard.parentNode) {
      firstCard.parentNode.insertBefore(bar, firstCard);
    } else {
      anchor.insertBefore(bar, anchor.firstChild);
    }

    // 3) Updater: parse current bias + headlines/hr from visible text
    function extractBiasNumber(){
      try{
        var full = document.body.textContent || '';
        var m = full.match(/Bias[^()]*\(\s*(-?\d+(?:\.\d+)?)\s*\)/i);
        if (m) return parseFloat(m[1]);
      }catch(e){}
      return null;
    }
    function extractBiasLabel(){
      try{
        // look near the "Bias:" chip/line
        var biasLine = Array.from(document.querySelectorAll('*'))
          .find(n => n.textContent && n.textContent.trim().startsWith('Bias:'));
        if (biasLine){
          var txt = biasLine.textContent;
          var m = txt.match(/Bias:\s*([a-zA-Z]+)/);
          if (m) return m[1].toLowerCase();
        }
      }catch(e){}
      return 'neutral';
    }
    function extractHeadlinesHr(){
      try{
        var drv = Array.from(document.querySelectorAll('*')).find(n => n.textContent && n.textContent.indexOf('Headlines/hr')!==-1);
        if (drv){
          var m = drv.textContent.match(/Headlines\/hr\s+(\d+)/);
          if (m) return parseInt(m[1],10);
        }
      }catch(e){}
      return null;
    }

    function pickAction(b){
      if (b==null) return {text:'Wait', tone:'amber'};
      if (b >= 65 || b <= 35) return {text:'Act (small, tight stops)', tone:'green'};
      if ((b >= 55 && b <= 64) || (b >= 36 && b <= 45)) return {text:'Scout with bias', tone:'amber'};
      return {text:'Wait', tone:'amber'}; // 46–54
    }

    function render(){
      var bNum = extractBiasNumber();
      var bLbl = extractBiasLabel();
      var h = extractHeadlinesHr();

      var nowTxt = 'Now: Bias ' + (bLbl||'neutral') + (bNum!=null?(' '+bNum):'');
      if (h!=null) nowTxt += ' • Headlines '+h+'/hr';

      nowSpan.textContent = nowTxt;

      var act = pickAction(bNum);
      actSpan.textContent = 'Action: ' + act.text;
      pill(actSpan, act.tone);
    }

    render();
    setInterval(render, 15000); // refresh every 15s
  } catch (e) { /* no-op */ }
})();
</script>
