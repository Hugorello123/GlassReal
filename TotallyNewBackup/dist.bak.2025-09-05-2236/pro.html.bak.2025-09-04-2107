<!-- Patch NA-02: Action tooltip (friendly explainer; reversible) -->
<script>
(function () {
  try {
    // Require NA-01 elements
    var act = document.getElementById('now-action-act');
    if (!act || document.getElementById('now-action-help')) return;

    // Tooltip element
    var tip = document.createElement('div');
    tip.id = 'now-action-help';
    tip.style.position = 'fixed';
    tip.style.zIndex = '9999';
    tip.style.maxWidth = '320px';
    tip.style.padding = '10px 12px';
    tip.style.border = '1px solid rgba(255,255,255,0.12)';
    tip.style.borderRadius = '10px';
    tip.style.background = 'rgba(20,20,24,0.96)';
    tip.style.boxShadow = '0 8px 24px rgba(0,0,0,0.35)';
    tip.style.fontSize = '12px';
    tip.style.lineHeight = '1.45';
    tip.style.color = 'rgba(255,255,255,0.92)';
    tip.style.backdropFilter = 'saturate(120%) blur(8px)';
    tip.style.display = 'none';
    tip.style.pointerEvents = 'none';

    // Friendly content (plain-English)
    tip.innerHTML =
      '<div style="font-weight:600;margin-bottom:6px;">Action guide</div>' +
      '<div style="opacity:.9;margin-bottom:6px;">' +
      'Use this as a quick read on the next 1–6h.' +
      '</div>' +
      '<ul style="padding-left:16px;margin:0 0 6px 0;">' +
        '<li><b>Strong bias (≥65 or ≤35)</b>: “<b>Act</b>”. Trade with the trend, keep <b>tight stops</b>.</li>' +
        '<li><b>Mild bias (55–64 or 36–45)</b>: “<b>Scout</b>”. Test small; wait for confirmation.</li>' +
        '<li><b>Neutral (46–54)</b>: “<b>Wait</b>”. No edge; avoid chop.</li>' +
      '</ul>' +
      '<div style="opacity:.9;">' +
        '<b>Heads-up:</b> if <b>Headlines ≥3/hr</b>, expect faster moves &amp; bigger swings.' +
      '</div>';

    document.body.appendChild(tip);

    // Accessible fallback (title) for long-press on mobile
    act.title = 'Action guide — Strong (≥65/≤35): Act; Mild (55–64/36–45): Scout; Neutral (46–54): Wait. If headlines ≥3/hr, expect faster moves.';

    // Position & show/hide
    function showTip(e) {
      const rect = act.getBoundingClientRect();
      const pad = 8;
      // Default above the pill; if not enough space, place below
      var top = rect.top - tip.offsetHeight - pad;
      var left = rect.left;

      tip.style.display = 'block';
      // Measure after display to get height
      var needAbove = rect.top >= (tip.offsetHeight + 16);
      if (!needAbove) top = rect.bottom + pad;

      // Prevent overflow on the right edge
      var maxLeft = window.innerWidth - tip.offsetWidth - 12;
      left = Math.max(12, Math.min(left, maxLeft));

      tip.style.top = Math.round(top) + 'px';
      tip.style.left = Math.round(left) + 'px';
    }
    function hideTip() { tip.style.display = 'none'; }

    act.setAttribute('tabindex', '0'); // keyboard focusable
    act.setAttribute('aria-describedby', 'now-action-help');

    act.addEventListener('mouseenter', showTip);
    act.addEventListener('mouseleave', hideTip);
    act.addEventListener('focus', showTip);
    act.addEventListener('blur', hideTip);
  } catch (e) { /* no-op */ }
})();
</script>
