    while (tbody.firstChild) tbody.removeChild(tbody.firstChild);
    if (!rows || !rows.length){
      var r = document.createElement('tr');
      var c = document.createElement('td');
      c.colSpan = 5; c.textContent = 'No recent signals yet.'; c.style.padding='6px'; c.style.opacity='0.8';
      r.appendChild(c); tbody.appendChild(r); return;
    }
    rows.slice(0,5).forEach(function(raw){
      var x = normalize(raw);
      var tr = document.createElement('tr');
      tr.appendChild(td(fmtTime(x.t)));
      tr.appendChild(td(String(x.sig)));
      var whyCell = td(String(x.why || '').slice(0,64));
      whyCell.style.maxWidth = '320px'; whyCell.style.overflow='hidden'; whyCell.style.textOverflow='ellipsis';
      tr.appendChild(whyCell);
      tr.appendChild(td(String(x.horizon)));
      tr.appendChild(td(String(x.outcome)));
      tbody.appendChild(tr);
    });
  }

  // 4) Try once now; refresh every 60s (read-only)
  getRecent().then(render);
  setInterval(function(){ getRecent().then(render); }, 60000);
})();
</script>
<!-- BIND-01 (fixed): expose bias number for Signal/A1 -->
<script>
(function(){
  // Grab bias from the full page text (handles split DOM nodes like "Bias:" + "(51)")
  function extractBias(){
    try {
      var full = (document.body && document.body.textContent) ? document.body.textContent : '';
      var m = full.match(/Bias[^()]*\(\s*(-?\d+(?:\.\d+)?)\s*\)/i);
      if (m) return parseFloat(m[1]);

      // Fallback: look for a dedicated bias element/attr if present
      var cand = document.querySelector('#bias-score,.bias-score,[data-bias],#biasValue,[data-role="bias-score"],[data-testid="bias-score"]');
      if (cand){
        var raw = (cand.getAttribute('data-bias') || cand.textContent || '').replace(/[^\d.\-:]/g,'');
        if (raw.includes(':')) raw = raw.split(':').pop();
        var v = parseFloat(raw);
        if (Number.isFinite(v)) return v;
      }
    } catch(e) {}
    return NaN;
  }

  function ensureCarrier(){
    var el = document.getElementById('biasValue');
    if (!el){
      el = document.createElement('span');
      el.id = 'biasValue';
      el.style.display = 'none';
      document.body.appendChild(el);
    }
    return el;
  }

  function tick(){
    var n = extractBias();
    if (!Number.isNaN(n)){
      var c = ensureCarrier();
      c.setAttribute('data-bias', String(n));
      c.textContent = String(n); // also set textContent for other readers
    }
  }

  tick();
  setInterval(tick, 5000);
})();
</script>

<!-- FLOW-BIND-02 (v2): expose BTC/ETH/USDT(ETH) tokens -->
<script>
(function(){
  function qAll(sel){ return document.querySelectorAll(sel); }
  function carrier(id, key){
    var n = document.getElementById(id);
    if(!n){
      n = document.createElement('span');
      n.id = id;
      n.className = 'flow-' + key;
      n.setAttribute('data-flow', key);
      n.style.display = 'none';
      document.body.appendChild(n);
    }
    return n;
  }
  function text(el){ return (el && el.textContent) ? el.textContent.trim() : ''; }
  function findByPrefix(prefix){
    var re = new RegExp('^\\s*' + prefix.replace(/[.*+?^${}()|[\]\\]/g,'\\$&') + '\\s*:', 'i');
    var els = qAll('span,div,li,button,a,p');
    for (var i=0;i<els.length;i++){
      if (re.test(text(els[i]))) return els[i];
    }
    return null;
  }
  function num(re, s){
    var m = s.match(re);
    return m ? parseFloat(m[1].replace(/[, ]/g,'')) : NaN;
  }

  function scan(){
    // BTC: "BTC: to X / from Y ..."
    var btcEl = findByPrefix('BTC');
    if (btcEl){
      var s = text(btcEl);
      var to   = num(/to\s*([0-9][0-9,.\s]*)/i, s);
      var from = num(/from\s*([0-9][0-9,.\s]*)/i, s);
      var token = 'BTC flat';
      if (isFinite(to) && isFinite(from)){
        if (from > to) token = 'BTC outflow';
        else if (to > from) token = 'BTC inflow';
      }
      carrier('btc-flow','btc').textContent = token;
    }

    // ETH: "ETH: to X / from Y ..."
    var ethEl = findByPrefix('ETH');
    if (ethEl){
      var s2 = text(ethEl);
      var to2   = num(/to\s*([0-9][0-9,.\s]*)/i, s2);
      var from2 = num(/from\s*([0-9][0-9,.\s]*)/i, s2);
      var token2 = 'ETH flat';
      if (isFinite(to2) && isFinite(from2)){
        if (from2 > to2) token2 = 'ETH outflow';
        else if (to2 > from2) token2 = 'ETH inflow';
      }
      carrier('eth-flow','eth').textContent = token2;
    }

    // USDT(ETH): "USDT(ETH): mints $X / burns $Y"
    var usdtEl = findByPrefix('USDT(ETH)');
    if (usdtEl){
      var s3 = text(usdtEl);
      var mints = num(/mints?\s*\$?\s*([0-9][0-9,.\s]*)/i, s3);
      var burns = num(/burns?\s*\$?\s*([0-9][0-9,.\s]*)/i, s3);
      var token3 = 'USDT flat';
      if (isFinite(mints) && isFinite(burns)){
        if (mints > burns) token3 = 'USDT mint';
        else if (burns > mints) token3 = 'USDT burn';
      }
      carrier('usdt-eth-flow','usdt-eth').textContent = token3;
    }
  }

  scan();
  setInterval(scan, 10000);
})();
</script>
<!-- Patch T1: Signal caption, link rename, and tooltips (no DOM rewrites) -->
<script>
(function(){
  if (document.getElementById('signal-caption-applied')) return; // guard

  function onReady(fn){
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', fn);
    else fn();
  }

  onReady(function(){
    var tries = 0;
    (function apply(){
      var strip = document.getElementById('signal-strip');
      if (!strip && tries++ < 80) return setTimeout(apply, 125); // wait up to ~10s for strip
      if (!strip) return;

      // mark so we never double-apply
      var mark = document.createElement('span');
      mark.id = 'signal-caption-applied';
      mark.style.display = 'none';
      document.body.appendChild(mark);

      // 1) Caption: "Next 1–6h bias" (above the strip)
      if (!document.getElementById('signal-caption')){
        var cap = document.createElement('div');
        cap.id = 'signal-caption';
        cap.textContent = 'Next 1–6h bias';
        cap.style.fontSize = '12px';
        cap.style.opacity = '0.75';
        cap.style.marginTop = '10px';
        cap.style.marginBottom = '6px';
        strip.parentNode.insertBefore(cap, strip);

        // Tiny help glyph
        var info = document.createElement('span');
        info.id = 'signal-caption-info';
        info.textContent = ' ⓘ';
        info.style.opacity = '0.6';
        info.style.cursor = 'help';
        info.title = 'How to use: Risk-on → buy dips / ride momentum; Neutral → range-trade; Risk-off → reduce longs / hedge. Horizon: next 1–6 hours.';
        cap.appendChild(info);
      }

      // 2) Rename link to "Setups (1–6h)" but keep the same href
      var link = strip.querySelector('a[href="/predictions.html"]') || strip.querySelector('a');
      if (link){
        link.textContent = 'Setups (1–6h)';
        link.title = 'Open Setups (1–6h)';
        link.setAttribute('aria-label', 'Open Setups (1–6h)');
      }

      // 3) Tooltips for the strip + bits (“toolclip”)
      var label = document.getElementById('signal-label');
      var why   = document.getElementById('signal-why');
      var tt = 'Signal = next 1–6h bias (Risk-on / Neutral / Risk-off). “Why” summarizes deterministic inputs (Bias level + flows).';
      strip.title = tt;
      if (label) label.title = 'Headline bias for the next 1–6 hours';
      if (why)   why.title   = 'Drivers snapshot (Bias bucket and flow tokens)';
    })();
  });
})();
</script>

