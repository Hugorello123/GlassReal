# ===== GlassTrade Environment Variables =====
# Copy this file to .env and fill in your API keys

# --- Frontend (Vite) ---
VITE_POLYGON_KEY=your_polygon_api_key_here
VITE_POLYGON_API_KEY=your_polygon_api_key_here
VITE_FMP_KEY=your_financial_modeling_prep_key_here
VITE_NEWSCATCHER_KEY=your_rapidapi_newscatcher_key_here
VITE_BITQUERY_TOKEN=your_bitquery_token_here
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id
VITE_PAYPAL_PLAN_ID=your_paypal_plan_id
VITE_BASE_URL=http://localhost:8080

# --- Server / Backend ---
PORT=8080
DATABASE_URL=postgresql://USER:PASS@HOST:PORT/DBNAME
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
COVALENT_API_KEY=
COINGECKO_API_KEY=
ALPHA_VANTAGE_API_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox
SESSION_SECRET=your_random_session_secret_here
ADMIN_EMAILS=
ADMIN_PASSWORD=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
